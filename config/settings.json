{
  "application": {
    "name": "god_platform",
    "version": "1.0.0",
    "environment": "production"
  },
  "logging": {
    "level": "INFO",
    "filePath": "logs/app.log",
    "maxFileSize": "10MB",
    "backupCount": 3
  },
  "database": {
    "type": "PostgreSQL",
    "host": "localhost",
    "port": 5432,
    "username": "db_user",
    "password": "secure_password",
    "database_name": "god_db"
  },
  "api": {
    "host": "0.0.0.0",
    "port": 8080,
    "route_prefix": "api/v1"
  },
  "data_sources": {
    "input_data_path": "data/input/",
    "processed_data_path": "data/processed/",
    "output_data_path": "data/output/",
    "training_data_file": "data/training_data.csv",
    "testing_data_file": "data/testing_data.csv"
  },
  "security": {
    "enable_encryption": true,
    "encryption_key": "my_secret_key",
    "allow_listed_ips": [
      "127.0.0.1",
      "192.168.1.1"
    ],
    "jwt_secret": "replace_this_with_a_secret_key"
  },
  "features": {
    "enable_data_pipeline": true,
    "enable_model_training": true,
    "enable_real_time_monitoring": false
  },
  "limits": {
    "max_concurrent_tasks": 5,
    "memory_limit": "4GB",
    "timeout": 300
  },
  "dependencies": [
    "numpy",
    "pandas",
    "scikit-learn",
    "tensorflow"
  ]
}