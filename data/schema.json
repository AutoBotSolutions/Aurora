{
  "data_source": {
    "type": "string",
    "required": true,
    "description": "Source of the data (e.g., 'database', 'csv', etc.)"
  },
  "model": {
    "type": "string",
    "required": true,
    "description": "Model type to be used (e.g., 'RandomForestClassifier')."
  },
  "training_data_path": {
    "type": "string",
    "required": true,
    "description": "Path to the training data file."
  },
  "deployment_path": {
    "type": "string",
    "required": true,
    "description": "Path where the model will be deployed or saved."
  },
  "parameters": {
    "type": "object",
    "required": false,
    "properties": {
      "n_estimators": {
        "type": "integer",
        "required": false,
        "description": "Number of trees in the forest."
      },
      "max_depth": {
        "type": "integer",
        "required": false,
        "description": "Maximum depth of the tree."
      },
      "random_state": {
        "type": "integer",
        "required": false,
        "description": "Seed for random number generation."
      }
    },
    "description": "Model-specific hyperparameters."
  },
  "metadata": {
    "type": "object",
    "required": false,
    "properties": {
      "project_name": {
        "type": "string",
        "required": true,
        "description": "The name of the pipeline project."
      },
      "created_by": {
        "type": "string",
        "required": false,
        "description": "The name of the person or entity who created the file."
      },
      "created_at": {
        "type": "string",
        "format": "date-time",
        "required": false,
        "description": "Timestamp indicating when the file was created."
      }
    },
    "description": "Metadata about the pipeline project."
  }
}